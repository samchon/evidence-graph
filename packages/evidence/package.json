{
  "name": "@samchon/evidence-graph",
  "version": "0.1.0",
  "description": "Evidence-graph lint contributor for @ttsc/lint: declare provenance with a JSDoc @evidence tag and fail the build when it is missing or dangling.",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "README.md",
    "go.mod",
    "lib",
    "native",
    "src"
  ],
  "scripts": {
    "build": "rimraf lib && tsc",
    "prepack": "pnpm run build"
  },
  "keywords": [
    "ttsc",
    "lint",
    "evidence",
    "provenance",
    "traceability",
    "jsdoc",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/samchon/evidence-graph"
  },
  "author": "Jeongho Nam",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/samchon/evidence-graph/issues"
  },
  "peerDependencies": {
    "@ttsc/lint": ">=0.20.0"
  },
  "devDependencies": {
    "@ttsc/lint": "catalog:typescript",
    "@types/node": "catalog:utils",
    "rimraf": "catalog:utils",
    "ttsc": "catalog:typescript",
    "typescript": "catalog:typescript"
  }
}
